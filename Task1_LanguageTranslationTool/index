<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Language Translator</title>

<link rel="stylesheet" href="css/style.css">
</head>

<body>
<div class="container">
  <h1>Language Translator</h1>
  <p class="subtitle">
    Translate text instantly across 100+ languages
  </p>
  <div class="divider"></div>
  <div class="controls">
    <select id="srcLang">
      <option value="auto">🔍 Auto Detect</option>
      <option value="" disabled>── or choose ──</option>
      <option value="te">🇮🇳 Telugu</option>
      <option value="hi">🇮🇳 Hindi</option>
      <option value="ta">🇮🇳 Tamil</option>
      <option value="kn">🇮🇳 Kannada</option>
      <option value="ml">🇮🇳 Malayalam</option>
      <option value="bn">🇮🇳 Bengali</option>
      <option value="mr">🇮🇳 Marathi</option>
      <option value="en">🇬🇧 English</option>
      <option value="fr">🇫🇷 French</option>
      <option value="de">🇩🇪 German</option>
      <option value="es">🇪🇸 Spanish</option>
      <option value="pt">🇵🇹 Portuguese</option>
      <option value="it">🇮🇹 Italian</option>
      <option value="ja">🇯🇵 Japanese</option>
      <option value="zh-CN">🇨🇳 Chinese (Simplified)</option>
      <option value="ko">🇰🇷 Korean</option>
      <option value="ar">🇸🇦 Arabic</option>
      <option value="ru">🇷🇺 Russian</option>
    </select>
    <button class="swap-btn" onclick="swapLangs()" title="Swap">⇄</button>
    <select id="tgtLang">
      <option value="" disabled selected>🎯 Target language</option>
      <option value="en">🇬🇧 English</option>
      <option value="te">🇮🇳 Telugu</option>
      <option value="hi">🇮🇳 Hindi</option>
      <option value="ta">🇮🇳 Tamil</option>
      <option value="kn">🇮🇳 Kannada</option>
      <option value="ml">🇮🇳 Malayalam</option>
      <option value="bn">🇮🇳 Bengali</option>
      <option value="mr">🇮🇳 Marathi</option>
      <option value="fr">🇫🇷 French</option>
      <option value="de">🇩🇪 German</option>
      <option value="es">🇪🇸 Spanish</option>
      <option value="pt">🇵🇹 Portuguese</option>
      <option value="it">🇮🇹 Italian</option>
      <option value="ja">🇯🇵 Japanese</option>
      <option value="zh-CN">🇨🇳 Chinese (Simplified)</option>
      <option value="ko">🇰🇷 Korean</option>
      <option value="ar">🇸🇦 Arabic</option>
      <option value="ru">🇷🇺 Russian</option>
    </select>
  </div>
  <div class="main-box">
    <div class="panel input-panel">
      <label>
        Input
        <span id="badge" class="badge" style="display:none">ENGLISH TYPING ON</span>
      </label>
      <!-- AUTO-DETECT BADGE shown in top-right corner of this panel -->
      <span id="detectedBadge"></span>
      <div id="translitPreview" class="translit-preview"></div>
      <textarea id="inputText" placeholder="Type your text here..." oninput="onInput()"></textarea>
    </div>
    <div class="panel output-panel">
      <label>Translation</label>
      <textarea id="resultText" readonly placeholder="Translation appears here..."></textarea>
    </div>
  </div>

  <div style="text-align:center;margin-top:20px;">
    <label style="font-weight:800;cursor:pointer;">
      <input type="checkbox" id="liveTranslate">
       Live Translation
    </label>
  </div>

  <div class="buttons">
    <button id="translateBtn" onclick="doTranslate()">🌐 Translate</button>
    <button class="btn-copy" onclick="doCopy()">📋 Copy</button>
    <button class="btn-speak" onclick="doSpeak()">🔊 Speak</button>
    <button class="btn-clear" onclick="doClear()">🗑 Clear</button>
  </div>
  <div id="status"></div>
  <div class="divider"></div>
</div>

<script src="js/languages.js"></script>
<script src="js/transliteration.js"></script>
<script src="js/detection.js"></script>
<script src="js/speech.js"></script>
<script src="js/translator.js"></script>
<script src="js/app.js"></script>

</body>
</html>
